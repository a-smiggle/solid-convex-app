# Convex backend environment variables (template)
# Copy this to .env.convex.local and fill in real values.
# Upload with:
#   pnpm convex env set --from-file .env.convex.local
# Or for production:
#   pnpm convex env set --from-file .env.convex.local --prod

# Optional JWT/JWKS settings (only needed for custom JWT auth flows):
# - Current email/password, reset, verification, and GitHub OAuth flows do not require these.
# - Leave these commented out unless you have a feature that reads them.
#JWKS='{"keys":[{"kty":"RSA","use":"sig","n":"<public-modulus>","e":"AQAB"}]}'
#JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<private-key-material>\n-----END PRIVATE KEY-----"

# GitHub OAuth (required for GitHub sign-in)
GITHUB_CLIENT_ID="your_github_oauth_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# Email provider (required for reset + verification emails)
RESEND_API_KEY="your_resend_api_key"

# Password reset email settings
RESET_EMAIL_FROM="admin@yourdomain.com"
RESET_EMAIL_APP_NAME="Solid Convex Starter"
RESET_PASSWORD_URL="http://localhost:5173/"

# Email verification settings for signup activation
VERIFY_EMAIL_FROM="admin@yourdomain.com"
VERIFY_EMAIL_APP_NAME="Solid Convex Starter"
VERIFY_EMAIL_URL="http://localhost:5173/"
